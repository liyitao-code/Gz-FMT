<?xml version='1.0'?>
<sdf version='1.7'>
  <!-- 基本立方体模型 -->
  <model name="example_box">
    <!-- 初始位置和姿态 -->
    <pose>0 0 0.5 0 0 0</pose>
    
    <!-- 主连杆 -->
    <link name="base_link">
      <!-- 物理属性 -->
      <inertial>
        <mass>1.0</mass>  <!-- 质量（kg） -->
        <inertia>
          <ixx>0.0833</ixx>  <!-- 惯性矩阵 -->
          <iyy>0.0833</iyy>
          <izz>0.0833</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>

      <!-- 碰撞属性 -->
      <collision name="collision">
        <geometry>
          <box>
            <size>1.0 1.0 1.0</size>  <!-- 尺寸（长宽高） -->
          </box>
        </geometry>
      </collision>
  </model>
</sdf>