<?xml version="1.0" ?>

<sdf version="1.6">
  <world name="default">
    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.8 0.8 0.8 1</ambient>
            <diffuse>0.8 0.8 0.8 1</diffuse>
            <specular>0.8 0.8 0.8 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- 加载 gazebo_ros 插件 -->
    <plugin name="gazebo_ros" filename="libgazebo_ros_init.so">
      <ros>
        <!-- 设置 ROS 命名空间 -->
        <namespace></namespace>
      </ros>
    </plugin>

    <!-- 加载 factory 插件，用于支持 /spawn_entity 和 /delete_entity 等服务 -->
    <plugin name="gazebo_ros_factory" filename="libgazebo_ros_factory.so"/>

    <!-- 加载 state 插件，用于支持状态相关的服务 -->
    <plugin name="gazebo_ros_state" filename="libgazebo_ros_state.so"/>

    <!-- 加载 clock 插件，用于发布 /clock 话题 -->
    <plugin name="gazebo_ros_clock" filename="libgazebo_ros_clock.so"/>
  </world>
</sdf>
